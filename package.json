{
  "name": "lgu-research-portal",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "build": "corepack pnpm --filter api build && corepack pnpm --filter web build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "turbo run format",
    "db:generate": "pnpm --filter api prisma:generate",
    "db:push": "pnpm --filter api exec prisma db push",
    "db:migrate": "pnpm --filter api prisma:migrate",
    "db:seed": "pnpm --filter api prisma:seed",
    "infra:up": "docker compose up -d",
    "infra:down": "docker compose down"
  },
  "devDependencies": {
    "turbo": "^2.1.3"
  }
}
